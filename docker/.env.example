# Host port mappings (container internal ports are fixed)
JAVA_HOST_PORT=80
PYTHON_HOST_PORT=8080
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379

# Database and cache credentials
MYSQL_ROOT_PASSWORD=replace_with_mysql_root_password
BUCTTA_JAVA_DB_PASSWORD=replace_with_java_db_password
BUCTTA_PYTHON_DB_PASSWORD=replace_with_python_db_password
REDIS_PASSWORD=replace_with_redis_password
