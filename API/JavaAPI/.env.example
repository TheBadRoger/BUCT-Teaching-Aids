# JavaAPI standalone deployment env vars
# Copy this file to .env in the same directory and fill real values.

# Ports
SERVER_PORT=80
MYSQL_HOST=localhost
MYSQL_PORT=3306
REDIS_HOST=localhost
REDIS_PORT=6379

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Explicit Docker Compose switch in dev profile (true=use compose, false=disable)
SPRING_DOCKER_COMPOSE_ENABLED=false

# Local database password for standalone deployment
BUCTTA_JAVA_DB_PASSWORD=replace_with_java_db_password

# Admin account for standalone deployment
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=replace_with_admin_password

# Redis password for standalone deployment
REDIS_PASSWORD=replace_with_redis_password

