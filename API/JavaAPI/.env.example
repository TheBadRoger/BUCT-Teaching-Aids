# JavaAPI standalone deployment env vars
# Copy this file to .env in the same directory and fill real values.

# Spring profile and server
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=80

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
BUCTTA_JAVA_DB_PASSWORD=replace_with_java_db_password
# Optional fallback if you prefer root account locally
# MYSQL_ROOT_PASSWORD=replace_with_mysql_root_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_redis_password

