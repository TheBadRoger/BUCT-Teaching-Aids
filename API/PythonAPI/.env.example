# 复制本文件并重命名为 .env，填写真实配置后启动项目

# Flask
SECRET_KEY=请替换为随机安全密钥
PORT=5000
DEBUG=false

# MySQL 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=python_flask_buctta
MYSQL_PASSWORD=${BUCTTA_PYTHON_DB_PASSWORD}
MYSQL_DB=BUCTTA_DATABASE
# 也可以直接设置完整连接字符串（优先级更高）
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/BUCTTA_DATABASE?charset=utf8mb4

# 摄像头（face_hand_up 模块）
# 0 = 内置摄像头，1/2 = 外接摄像头，或填写视频文件路径
CAMERA_ID=0

# 人脸库路径（face_hand_up 模块）
# 默认使用项目根目录下的 face_database/人脸库
# FACE_DB_PATH=/path/to/face_database/人脸库

# YOLO 模型路径（headup_rate 模块）
# 首次运行时 ultralytics 会自动下载 yolov8n-pose.pt
# YOLO_MODEL_PATH=yolov8n-pose.pt

# 上传目录（PBL 模块）
# UPLOAD_DIR=/path/to/uploads

# AI 课堂 SQLite 数据库路径
# CLASSROOM_DB_PATH=/path/to/classroom_data.db
