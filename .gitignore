# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Binary files
*.xslx

# Testing files
/API/JavaAPI/temp/

# Secret environment files
**/.env
**/.env.*
!**/.env.example

# Python cache
__pycache__/
*.pyc

# JetBrains local state (shared configs in .idea are intentionally versioned)
.idea/workspace.xml
.idea/tasks.xml
.idea/shelf/
.idea/httpRequests/
.idea/queries/
.idea/dataSources/
.idea/dataSources.local.xml
